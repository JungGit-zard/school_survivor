{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['schemaVersion', 'updatedAt', 'profile', 'progress'])",
        "schemaVersion": { ".validate": "newData.isNumber() && newData.val() === 1" },
        "updatedAt": { ".validate": "newData.isString() && newData.val().length <= 40" },
        "profile": {
          ".validate": "newData.hasChildren(['uid', 'displayName', 'nickname'])",
          "uid": { ".validate": "newData.isString() && newData.val() === $uid" },
          "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "nickname": { ".validate": "newData.isString() && newData.val().length <= 12" },
          "$other": { ".validate": false }
        },
        "progress": {
          ".validate": "newData.hasChildren(['goldTotal', 'records', 'weaponUnlocks', 'weaponPermanentUpgrades', 'passiveUpgrades', 'titleSettings'])",
          "goldTotal": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000000" },
          "records": {
            "$recordKey": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000000" }
          },
          "weaponUnlocks": {
            "$weaponId": { ".validate": "newData.val() === 1" }
          },
          "weaponPermanentUpgrades": {
            "$weaponId": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10 && newData.val() % 1 === 0" }
          },
          "passiveUpgrades": {
            "$passiveId": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100 && newData.val() % 1 === 0" }
          },
          "titleSettings": {
            ".validate": "newData.hasChildren(['vibration', 'reducedEffects', 'unlockAllWeaponsCheat', 'unlockAllStagesCheat'])",
            "vibration": { ".validate": "newData.isBoolean()" },
            "reducedEffects": { ".validate": "newData.isBoolean()" },
            "unlockAllWeaponsCheat": { ".validate": "newData.isBoolean()" },
            "unlockAllStagesCheat": { ".validate": "newData.isBoolean()" },
            "$other": { ".validate": false }
          },
          "$other": { ".validate": false }
        },
        "activity": {
          "lastStartedAt": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "lastStageId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "$other": { ".validate": false }
        },
        "$other": { ".validate": false }
      }
    },
    "studioWorkspaces": {
      "v1": {
        "users": {
          "$uid": {
            "current": {
              ".read": "auth != null && auth.uid === $uid",
              ".write": "auth != null && auth.uid === $uid",
              ".validate": "newData.hasChildren(['schemaVersion', 'revision', 'updatedAt'])",
              "schemaVersion": { ".validate": "newData.isNumber() && newData.val() === 1" },
              "revision": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() % 1 === 0" },
              "updatedAt": { ".validate": "newData.isString() && newData.val().length <= 40" },
              "datasets": {
                "tunings": { ".validate": "newData.isString() && newData.val().length <= 1000000" },
                "sfxTunings": { ".validate": "newData.isString() && newData.val().length <= 1000000" },
                "stageBossPreview": { ".validate": "newData.isString() && newData.val().length <= 1000000" },
                "decals": { ".validate": "newData.isString() && newData.val().length <= 1000000" },
                "propPlacements": { ".validate": "newData.isString() && newData.val().length <= 1000000" },
                "$other": { ".validate": false }
              },
              "$other": { ".validate": false }
            },
            "$other": { ".validate": false }
          }
        }
      }
    },
    "rankingService": {
      "v1": {
        "public": {
          "$seasonId": {
            "global": {
              "$window": {
                "$periodKey": {
                  "entries": {
                    ".read": "$window === 'daily' || $window === 'weekly'",
                    ".write": false,
                    ".indexOn": ["score"]
                  }
                }
              }
            },
            "stage": {
              "$stageId": {
                "daily": {
                  "$periodKey": {
                    "entries": {
                      ".read": "$stageId === 'stage1' || $stageId === 'stage2' || $stageId === 'stage3'",
                      ".write": false,
                      ".indexOn": ["score"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
