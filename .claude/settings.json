{
  "permissions": {
    "allow": [
      "PowerShell(Start-Process \"http://localhost:5175/\")",
      "Bash(git log *)",
      "PowerShell(Start-Process http://localhost:5175/)",
      "Bash(git fetch *)",
      "Bash(python3 -c ' *)",
      "Bash(py -3 -c ' *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      }
    ]
  }
}
